{
  "name": "@cognite/griff-react",
  "version": "0.5.0-rc.0",
  "description": "Charting library that relies on React's virtual diffing.",
  "main": "lib/index.js",
  "module": "es/index.js",
  "types": "lib/src/index.d.ts",
  "files": [
    "css",
    "es",
    "lib",
    "umd"
  ],
  "scripts": {
    "build": "yarn clean && yarn compile && rollup -c",
    "build:watch": "yarn rollup -w -c",
    "clean": "rm -rf build/ es/ lib/",
    "compile": "tsc -p .",
    "fix": "gts fix",
    "lint": "eslint 'src/**/*.{ts,tsx,js}' 'stories/**/*.{ts,tsx,js}'",
    "prepare": "yarn build",
    "prepush": "yarn lint && yarn test",
    "prettier": "prettier -l 'src/**/*.{js,ts,tsx}' || (echo '\nThese files are not formatted correctly' && false)",
    "prettier:fix": "prettier --write 'src/**/*.{js,ts,tsx}'",
    "release": "yarn clean && yarn build && node scripts/publish-release.js",
    "storybook": "start-storybook -p 9001",
    "storybook:build": "build-storybook -o .out",
    "test": "TZ=Europe/Oslo yarn jest",
    "test:watch": "TZ=Europe/Oslo yarn test --watchAll"
  },
  "dependencies": {
    "bluebird": "3.7.2",
    "d3": "^7.9.0",
    "immutable": "5.1.5",
    "lodash.isequal": "^4.5.0",
    "prop-types": "15.8.1",
    "react-resize-detector": "^12.0.0",
    "tslib": "2.8.1"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@cognite/eslint-config": "^1.4.2",
    "@cognite/react-scripts": "^4.0.0-9",
    "@emotion/core": "^10.0.10",
    "@storybook/addon-actions": "^5.2.5",
    "@storybook/addon-info": "^5.2.5",
    "@storybook/addon-knobs": "^5.2.5",
    "@storybook/react": "^5.2.5",
    "@testing-library/dom": "^10.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/d3": "^7.4.0",
    "@types/jest": "^29.0.0",
    "@types/lodash.isequal": "4.5.8",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-test-renderer": "^19.0.0",
    "awesome-typescript-loader": "^5.2.1",
    "axios": "^0.18.1",
    "babel-eslint": "10.1.0",
    "babel-loader": "^8.0.6",
    "chart.js": "^2.8.0",
    "csstype": "^2.6.3",
    "dts-bundle-generator": "^9.5.1",
    "eslint": "^6.6.0",
    "eslint-config-airbnb": "18.2.1",
    "eslint-config-prettier": "6.15.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jest": "23.20.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-prettier": "3.4.1",
    "eslint-plugin-react": "7.37.5",
    "gts": "^0.9.0",
    "husky": "^0.14.3",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^29.0.0",
    "moment": "2.30.1",
    "nodemon": "3.1.14",
    "plotly.js": "^1.44.4",
    "prettier": "^1.19.1",
    "react": "^19.0.0",
    "react-chartjs-2": "^2.7.6",
    "react-dom": "^19.0.0",
    "react-plotly.js": "2.6.0",
    "react-select": "^2.4.2",
    "react-test-renderer": "^19.0.0",
    "rollup": "^1.26.3",
    "rollup-plugin-json": "^4.0.0",
    "rollup-plugin-typescript2": "0.37.0",
    "semver": "6.3.1",
    "source-map-loader": "^0.2.4",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  },
  "author": "Cognite AS",
  "homepage": "https://griff.surge.sh/",
  "license": "Apache-2.0",
  "repository": "https://github.com/cognitedata/griff-react",
  "keywords": [
    "react-component"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
